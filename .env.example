# FinGuardX — Environment Configuration
# Copy this file to .env and fill in values before running
# NEVER commit .env with real secrets to version control

# ─── JWT ────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=finguardx-dev-secret-change-this-in-production-use-32-chars-minimum
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finguardx
DB_USER=finguardx
DB_PASSWORD=finguardx_secret
# Full connection string (alternative to individual vars above)
DATABASE_URL=postgresql://finguardx:finguardx_secret@localhost:5432/finguardx

# ─── FLASK ───────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Set to 'production' before deploying
# FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=false

# ─── RISK ENGINE ─────────────────────────────────────────────────────────────
MODEL_PATH=./model/risk_model.joblib
ENCODERS_PATH=./model/encoders.joblib
# Number of samples to generate for synthetic training data
TRAIN_SAMPLES=10000
# ML/Heuristic blend ratio (0.0 = pure heuristic, 1.0 = pure ML)
ML_BLEND_RATIO=0.5

# ─── MULTI-TENANCY ───────────────────────────────────────────────────────────
# Minimum number of concurrent tenants to support
MIN_TENANTS=5
# Session inactivity timeout (minutes)
SESSION_TIMEOUT_MINUTES=60

# ─── PERFORMANCE TARGETS (from SRS §5) ───────────────────────────────────────
# These are reference values; actual enforcement is in application logic
RISK_SCORE_SLA_SECONDS=2
DASHBOARD_LOAD_SLA_SECONDS=3
TARGET_UPTIME_PCT=99
TARGET_ACCURACY_PCT=85

# ─── FRONTEND ────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
# API base URL used by frontend (empty = same origin via nginx proxy)
# Set to http://localhost:8080 when running frontend as a file://
API_BASE_URL=

# ─── DOCKER ──────────────────────────────────────────────────────────────────
POSTGRES_DB=finguardx
POSTGRES_USER=finguardx
POSTGRES_PASSWORD=finguardx_secret
